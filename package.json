{
  "name": "@lifeforge/lifeforge--movies",
  "displayName": "Movies Library",
  "repository": {
    "type": "git",
    "url": "https://github.com/lifeforge-app/lifeforge-module-movies.git"
  },
  "version": "0.0.5",
  "type": "module",
  "author": "Melvin Chia <melvinchia623600@gmail.com>",
  "description": "Your personal log for every movie you\u2019ve watched.",
  "scripts": {
    "typecheck": "pnpm run typecheck:client && pnpm run typecheck:server",
    "typecheck:client": "cd client && tsc",
    "typecheck:server": "cd server && tsc",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "cd client && vite build",
    "build:server": "cd server && vite build"
  },
  "dependencies": {
    "jsdom": "^29.1.1",
    "language-name-map": "^0.3.0",
    "qrcode.react": "^4.2.0",
    "react-virtualized": "^9.22.6"
  },
  "devDependencies": {
    "@types/language-name-map": "^0.3.4",
    "@types/react-virtualized": "^9.22.3"
  },
  "lifeforge": {
    "icon": "tabler:movie",
    "category": "Lifestyle",
    "APIKeyAccess": {
      "tmdb": {
        "usage": "To fetch movie data from The Movie Database (TMDB) API",
        "required": false
      }
    }
  },
  "peerDependencies": {
    "@lifeforge/api": "workspace:*",
    "@lifeforge/server-utils": "workspace:*",
    "@lifeforge/pocketbase": "workspace:*",
    "@lifeforge/localization": "workspace:*",
    "@lifeforge/ui": "workspace:*",
    "@lifeforge/federation": "workspace:*",
    "@lifeforge/configs": "workspace:*"
  }
}
